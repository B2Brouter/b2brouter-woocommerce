msgid "Webhook URL"
msgstr "URL del webhook"

#: includes/Admin.php:828
msgid "Copied!"
msgstr "Copiat!"

#: includes/Admin.php:828 includes/Admin.php:829
msgid "Copy"
msgstr "Copia"

#: includes/Admin.php:832
msgid "Enter this URL in your B2Brouter dashboard webhook settings."
msgstr ""
"Introduïu aquesta URL a la configuració de webhooks del vostre panell de "
