msgid "Keep polling as backup (checks every 6 hours if webhook fails). Recommended for reliability."
msgstr "Mantener el sondeo como respaldo (verifica cada 6 horas si el webhook falla). Recomendado para fiabilidad."

#: includes/Admin.php:728
msgid "Invoice Numbering & Series"
msgstr "Numeración y series de facturas"

#: includes/Admin.php:732
msgid "Invoice Series Code"
msgstr "Código de serie de factura"

#: includes/Admin.php:740
msgid "e.g., INV, S01"
msgstr "p. ej., FAC, S01"

#: includes/Admin.php:742
msgid "Define one invoice series code for all invoices. B2Brouter allows one series per invoice type. Leave empty to use B2Brouter default."
msgstr "Defina un código de serie para todas las facturas. B2Brouter permite una serie por tipo de factura. Déjelo vacío para usar el valor predeterminado de B2Brouter."

#: includes/Admin.php:749
msgid "Credit Note Series Code"
msgstr "Código de serie de factura rectificativa"

#: includes/Admin.php:757
msgid "e.g., CN, R01"
msgstr "p. ej., NC, R01"

#: includes/Admin.php:759
msgid "Define one credit note series code for all credit notes. B2Brouter allows one series per type. Leave empty to use the same series as invoices."
msgstr "Defina un código de serie para todas las facturas rectificativas. B2Brouter permite una serie por tipo. Déjelo vacío para usar la misma serie que las facturas."

#: includes/Admin.php:766
msgid "Invoice Numbering Pattern"
msgstr "Patrón de numeración de facturas"

#: includes/Admin.php:775
msgid "Automatic (B2Brouter manages numbering)"
msgstr "Automático (B2Brouter gestiona la numeración)"

#: includes/Admin.php:777
msgid "Let B2Brouter automatically assign invoice numbers"
msgstr "Dejar que B2Brouter asigne automáticamente los números de factura"

#: includes/Admin.php:784
msgid "WooCommerce Order Number"
msgstr "Número de pedido de WooCommerce"

#: includes/Admin.php:786
msgid "Use the WooCommerce order number as the invoice number"
msgstr "Usar el número de pedido de WooCommerce como número de factura"

#: includes/Admin.php:793
msgid "Sequential (plugin-managed)"
msgstr "Secuencial (gestionado por el plugin)"

#: includes/Admin.php:795
msgid "Plugin maintains sequential numbering per series (starts at 1)"
msgstr "El plugin mantiene una numeración secuencial por serie (empieza en 1)"

#: includes/Admin.php:802
msgid "Custom Pattern"
msgstr "Patrón personalizado"

#: includes/Admin.php:812
msgid "Available placeholders: {order_id}, {order_number}, {year}, {month}, {day}. Note: Series code is defined separately above and will be prefixed automatically."
msgstr "Marcadores disponibles: {order_id}, {order_number}, {year}, {month}, {day}. Nota: El código de serie se define por separado arriba y se añadirá automáticamente como prefijo."

#: includes/Admin.php:819
msgid "PDF Options"
msgstr "Opciones de PDF"

#: includes/Admin.php:823
msgid "Automatic PDF Caching"
msgstr "Caché automática de PDF"

#: includes/Admin.php:832
msgid "Automatically download and cache PDF when invoice is generated"
msgstr "Descargar y almacenar en caché automáticamente el PDF cuando se genere la factura"

#: includes/Admin.php:835
msgid "When enabled, PDFs will be automatically downloaded from B2Brouter and stored locally when an invoice is generated. This improves performance and reduces API calls."
msgstr "Cuando está habilitado, los PDFs se descargarán automáticamente de B2Brouter y se almacenarán localmente cuando se genere una factura. Esto mejora el rendimiento y reduce las llamadas a la API."

#: includes/Admin.php:843
msgid "PDF Storage Location"
msgstr "Ubicación de almacenamiento de PDF"

#: includes/Admin.php:848
msgid "Invoice PDFs are stored in this directory. Files are protected from direct access via .htaccess rules."
msgstr "Los PDFs de facturas se almacenan en este directorio. Los archivos están protegidos contra el acceso directo mediante reglas .htaccess."

#: includes/Admin.php:866
#, php-format
msgid "Currently storing %d PDF(s) using %s of disk space"
msgstr "Actualmente almacenando %d PDF(s) usando %s de espacio en disco"

#: includes/Admin.php:875
msgid "Directory will be created automatically when first PDF is downloaded"
msgstr "El directorio se creará automáticamente cuando se descargue el primer PDF"

#: includes/Admin.php:883
msgid "Email PDF Attachments"
msgstr "Adjuntar PDF en correos electrónicos"

#: includes/Admin.php:892
msgid "Attach PDF to Order Completed email (sent to customer)"
msgstr "Adjuntar PDF al correo de pedido completado (enviado al cliente)"

#: includes/Admin.php:900
msgid "Attach PDF to Customer Invoice email"
msgstr "Adjuntar PDF al correo de factura del cliente"

#: includes/Admin.php:908
msgid "Attach PDF to Refunded Order email (credit note/rectificative)"
msgstr "Adjuntar PDF al correo de pedido reembolsado (factura rectificativa)"

#: includes/Admin.php:911
msgid "Automatically attach invoice PDFs to customer emails. \"Order Completed\" is sent when orders are fulfilled. \"Customer Invoice\" is sent for pending/unpaid orders or when manually sent from admin panel. \"Refunded Order\" is sent when orders are refunded."
msgstr "Adjuntar automáticamente PDFs de facturas a los correos del cliente. \"Pedido completado\" se envía cuando se completan los pedidos. \"Factura del cliente\" se envía para pedidos pendientes/impagados o cuando se envía manualmente desde el panel de administración. \"Pedido reembolsado\" se envía cuando se reembolsan los pedidos."

#: includes/Admin.php:919
msgid "Automatic Cleanup"
msgstr "Limpieza automática"

#: includes/Admin.php:928
msgid "Automatically delete old cached PDFs"
msgstr "Eliminar automáticamente los PDFs en caché antiguos"

#: includes/Admin.php:932
msgid "Delete PDFs older than"
msgstr "Eliminar PDFs con más de"

#: includes/Admin.php:939
msgid "days"
msgstr "días"

#: includes/Admin.php:942
msgid "When enabled, PDFs older than the specified number of days will be automatically deleted daily via cron job. This helps manage disk space usage."
msgstr "Cuando está habilitado, los PDFs con más días de los especificados se eliminarán automáticamente diariamente mediante una tarea cron. Esto ayuda a gestionar el uso del espacio en disco."

