#: includes/Admin.php:790
msgid "Invoice Numbering & Series"
msgstr "Numérotation et séries de factures"

#: includes/Admin.php:794
msgid "Invoice Series Code"
msgstr "Code de série de facture"

#: includes/Admin.php:802
msgid "e.g., INV, S01"
msgstr "p. ex., FAC, S01"

#: includes/Admin.php:804
msgid ""
"Define one invoice series code for all invoices. B2Brouter allows one series "
"per invoice type. Leave empty to use B2Brouter default."
msgstr ""
"Définissez un code de série pour toutes les factures. B2Brouter autorise une "
"série par type de facture. Laissez vide pour utiliser la valeur par défaut "
"de B2Brouter."

#: includes/Admin.php:811
msgid "Credit Note Series Code"
msgstr "Code de série d'avoir"

#: includes/Admin.php:819
msgid "e.g., CN, R01"
msgstr "p. ex., AV, R01"

